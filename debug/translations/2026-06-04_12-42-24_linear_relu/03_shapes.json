      "bias"
    ],
    "output_var": "z",
    "shape": "(N, D_out)"
  },
  "op_2_torch.relu": {
    "input_vars": [
      "z"
    ],
    "output_var": "_t3",
    "shape": "(N, D_out)"
  }
}