# Translation Service Environment Variables
# Copy this file to .env and fill in your values

# Required: NVIDIA API key for LLM generation
NVIDIA_API_KEY=nvapi-your-key-here

# Required for GPU validation via Modal
MODAL_TOKEN_ID=tk-your-token-id
MODAL_TOKEN_SECRET=ts-your-token-secret

# Optional: override database location
# DATABASE_URL=sqlite:///data/service.db
