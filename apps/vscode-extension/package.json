{
  "name": "triton-translator",
  "displayName": "Triton Translator",
  "description": "Traduce funciones PyTorch a kernels Triton usando el servicio dockerizado",
  "version": "0.1.0",
  "publisher": "triton-team",
  "repository": {
    "type": "git",
    "url": "https://github.com/triton-team/triton-translator.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Snippets"
  ],
  "activationEvents": [
    "onCommand:triton.translate",
    "onView:triton.history"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "triton.translate",
        "title": "Triton: Traducir función",
        "icon": "$(rocket)"
      },
      {
        "command": "triton.loadRun",
        "title": "Cargar generación del historial",
        "icon": "$(history)"
      },
      {
        "command": "triton.refreshHistory",
        "title": "Refrescar historial",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "triton.translate",
          "group": "9_cutcopypaste@5",
          "when": "true"
        }
      ],
      "view/title": [
        {
          "command": "triton.refreshHistory",
          "when": "view == triton.history",
          "group": "navigation"
        },
        {
          "command": "triton.translate",
          "when": "view == triton.history",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "triton-sidebar",
          "title": "Triton Translator",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "triton-sidebar": [
        {
          "id": "triton.history",
          "name": "Historial",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0",
    "vsce": "^2.15.0"
  }
}
